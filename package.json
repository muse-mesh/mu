{
  "name": "mu",
  "version": "0.1.0",
  "description": "AI agent harness with full local machine access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mu": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "cd web && npx vite",
    "build:web": "cd web && npx vite build",
    "build": "pnpm build:web && tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "start:web": "MU_BOT_WEB_UI_ENABLED=true node dist/index.js",
    "serve": "MU_BOT_WEB_UI_ENABLED=true tsx src/index.ts"
  },
  "keywords": [],
  "author": "Kush",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.32",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/react": "^3.0.0",
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.145",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "highlight.js": "^11.9.0",
    "hono": "^4.12.10",
    "marked": "^12.0.2",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0"
  }
}
